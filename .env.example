# Cron Expression Builder Environment Variables
# No backend required — all processing is client-side.
# Copy this file to .env if you need to override defaults.
#
# SECURITY: Never commit .env files with real API keys or secrets.
# .env is in .gitignore and should stay there.
# Only non-sensitive placeholder values belong in this .env.example file.

# Optional: Google Analytics tracking ID (non-sensitive, public ID)
VITE_GA_TRACKING_ID=

# Optional: Sentry DSN for error tracking (public DSN, not a secret)
VITE_SENTRY_DSN=
